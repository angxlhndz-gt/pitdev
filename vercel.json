{
  "rewrites": [
    {
      "source": "/card",
      "destination": "/index.html"
    },
    {
      "source": "/card/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/servicios",
      "destination": "/index.html"
    },
    {
      "source": "/servicios/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/productos",
      "destination": "/index.html"
    },
    {
      "source": "/productos/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/proyectos",
      "destination": "/index.html"
    },
    {
      "source": "/proyectos/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/contacto",
      "destination": "/index.html"
    },
    {
      "source": "/contacto/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/pitdev-wallet.pkpass",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.apple.pkpass"
        },
        {
          "key": "Content-Disposition",
          "value": "inline; filename=\"pitdev-wallet.pkpass\""
        }
      ]
    }
  ]
}
