{
  "rewrites": [
    {
      "source": "/card",
      "destination": "/index.html"
    },
    {
      "source": "/card/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/pitdev-wallet.pkpass",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.apple.pkpass"
        },
        {
          "key": "Content-Disposition",
          "value": "inline; filename=\"pitdev-wallet.pkpass\""
        }
      ]
    }
  ]
}
